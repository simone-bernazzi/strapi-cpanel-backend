{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": { "singularName": "category", "pluralName": "categories", "displayName": "Category" },
  "options": { "draftAndPublish": false },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "name": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "slug": { "type": "uid", "targetField": "name" },
    "description": { "type": "text", "pluginOptions": { "i18n": { "localized": true } } },
    "posts": { "type": "relation", "relation": "manyToMany", "target": "api::post.post", "mappedBy": "categories" }
  }
}
